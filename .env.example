DATABASE_URL=postgresql+psycopg://documind:documind@postgres:5432/documind
JWT_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_EXPIRE_DAYS=14
OPENAI_API_KEY=
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
LLAMA_BASE_URL=http://host.docker.internal:11434
LLAMA_MODEL=llama3
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=900
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5
MIN_RELEVANCE_SCORE=0.05
MAX_UPLOAD_SIZE_MB=15
UPLOAD_DIR=uploads
CHROMA_DIR=chroma_data
# Local development default. Set this to your deployed frontend URL(s) in production.
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]

# Render/Railway examples:
# UPLOAD_DIR=/app/data/uploads
# CHROMA_DIR=/app/data/chroma_data
# CORS_ORIGINS=["https://your-documind-frontend.vercel.app"]

# Frontend build-time value. For Vercel/Render static hosting, set this in the frontend service env.
VITE_API_URL=http://localhost:8000/api
